<?xml version="1.0" encoding="utf-8"?>
<!--
    dialog_transaction.xml
    Transaction detail popup dialog layout.
    Fields: Date-Time, Amount, Type, Party, Reference, Description (editable)
    Actions: Save | Close
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="320dp"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_dialog_rounded"
    android:padding="20dp">

    <!-- Dialog Title -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Transaction Details"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="#1565C0"
        android:paddingBottom="12dp" />

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#E0E0E0"
        android:layout_marginBottom="12dp"/>

    <!-- Date Time -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Date / Time"
        android:textSize="11sp"
        android:textColor="#78909C"
        android:textAllCaps="true"
        android:letterSpacing="0.05" />
    <TextView
        android:id="@+id/tvDialogDatetime"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="14sp"
        android:textColor="#263238"
        android:paddingBottom="10dp" />

    <!-- Amount -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Amount"
        android:textSize="11sp"
        android:textColor="#78909C"
        android:textAllCaps="true"
        android:letterSpacing="0.05" />
    <TextView
        android:id="@+id/tvDialogAmount"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="22sp"
        android:textStyle="bold"
        android:textColor="#263238"
        android:paddingBottom="10dp" />

    <!-- Type -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Transaction Type"
        android:textSize="11sp"
        android:textColor="#78909C"
        android:textAllCaps="true"
        android:letterSpacing="0.05" />
    <TextView
        android:id="@+id/tvDialogType"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="15sp"
        android:textStyle="bold"
        android:paddingBottom="10dp" />

    <!-- Party / Sender / Receiver -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Party (VPA / Merchant)"
        android:textSize="11sp"
        android:textColor="#78909C"
        android:textAllCaps="true"
        android:letterSpacing="0.05" />
    <TextView
        android:id="@+id/tvDialogParty"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="14sp"
        android:textColor="#263238"
        android:paddingBottom="10dp" />

    <!-- Reference Number -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Reference / UTR"
        android:textSize="11sp"
        android:textColor="#78909C"
        android:textAllCaps="true"
        android:letterSpacing="0.05" />
    <TextView
        android:id="@+id/tvDialogReference"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="13sp"
        android:fontFamily="monospace"
        android:textColor="#455A64"
        android:paddingBottom="12dp" />

    <!-- Divider before editable section -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#E0E0E0"
        android:layout_marginBottom="12dp"/>

    <!-- Description (Editable) -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Description (editable)"
        android:textSize="11sp"
        android:textColor="#78909C"
        android:textAllCaps="true"
        android:letterSpacing="0.05" />
    <EditText
        android:id="@+id/etDialogDescription"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minLines="2"
        android:maxLines="4"
        android:textSize="14sp"
        android:textColor="#263238"
        android:backgroundTint="#1565C0"
        android:inputType="textMultiLine|textCapSentences"
        android:hint="Enter a description..."
        android:layout_marginTop="4dp"
        android:layout_marginBottom="16dp" />

    <!-- Action Buttons Row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="end">

        <!-- Close (dismiss without saving) -->
        <Button
            android:id="@+id/btnClose"
            style="@style/Widget.AppCompat.Button.Borderless"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Close"
            android:textColor="#546E7A"
            android:layout_marginEnd="8dp" />

        <!-- Save description -->
        <Button
            android:id="@+id/btnSave"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Save"
            android:backgroundTint="@color/colorPrimary"
            android:textColor="#FFFFFF" />

    </LinearLayout>

</LinearLayout>
